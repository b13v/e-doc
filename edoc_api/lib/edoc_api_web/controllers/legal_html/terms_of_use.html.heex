    </a>
    <a href="/privacy-policy" class="inline-flex items-center justify-center rounded-2xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400">
      <%= if @locale == "kk", do: "Құпиялылық саясаты", else: "Политика конфиденциальности" %>
    </a>
  </div>
</section>
